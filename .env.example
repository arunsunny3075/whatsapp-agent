# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twilio ───────────────────────────────────────────────────
# From: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Twilio WhatsApp number that SENDS messages
# Sandbox:    whatsapp:+14155238886
# Production: whatsapp:+1XXXXXXXXXX  (your purchased number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# YOUR WhatsApp number (only this number can trigger the agent)
# Format: whatsapp:+91XXXXXXXXXX
ALLOWED_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# ─── Netlify ──────────────────────────────────────────────────
# From: https://app.netlify.com/user/applications → Personal access tokens
NETLIFY_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────────────
PORT=3000
